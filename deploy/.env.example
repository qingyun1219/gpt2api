# ================================================================
# docker-compose 环境变量模板。cp .env.example .env 后按需修改。
# ================================================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=HMt1LvfRDHzPozRZ
MYSQL_USER=gpt2api
MYSQL_PASSWORD=GbN8TX7eXeE8WCr4
MYSQL_DATABASE=gpt2api
MYSQL_PORT=13306

# ---- Redis ----
REDIS_PORT=16379

# ---- Server ----
HTTP_PORT=38080

# ---- Security (生产强制改!) ----
# JWT 签名密钥,至少 32 字符
JWT_SECRET=pnYKHCyAyYngFiK3YjmiuR6N4PM93wUYMxSe7BCGDpbtgO85
# AES-256 加密 KEY,用于加密账号的 AT/Cookie 等。必须 64 位 hex(32 字节)
CRYPTO_AES_KEY=c6b7c36c35c2e4a360eef9874f33a9cb461af8f136ad3d181104e5dd12b6328e

# ---- Base URL (对外域名,图片代理 URL 前缀) ----
# 部署后改成你的真实域名
APP_BASE_URL=https://gpt.jispul.com
# 保留最近 N 个备份,0 代表不清理
BACKUP_RETENTION=2
# 是否启用"数据库恢复"端点(超危)。生产默认 false,
# 需要恢复时先设置为 true 重启容器,完成后切回 false。
BACKUP_ALLOW_RESTORE=false